# Copie este arquivo para .env antes de subir a stack.
# O script scripts/manage.sh cria um .env automaticamente se ele não existir.

TZ=America/Bahia

# Gere um valor forte com: openssl rand -hex 32
GENIEACS_UI_JWT_SECRET=troque-este-valor-por-um-secret-forte

# Exposição de portas no host.
# Por segurança, NBI fica preso ao localhost por padrão.
UI_BIND=0.0.0.0
UI_PORT=3000
CWMP_BIND=0.0.0.0
CWMP_PORT=7547
FS_BIND=0.0.0.0
FS_PORT=7567
NBI_BIND=127.0.0.1
NBI_PORT=7557
