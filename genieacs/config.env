# Variáveis oficiais do GenieACS devem usar o prefixo GENIEACS_.
# Os segredos e portas vêm do arquivo .env carregado pelo Docker Compose.
GENIEACS_MONGODB_CONNECTION_URL=mongodb://mongodb:27017/genieacs
GENIEACS_CWMP_INTERFACE=0.0.0.0
GENIEACS_NBI_INTERFACE=0.0.0.0
GENIEACS_FS_INTERFACE=0.0.0.0
GENIEACS_UI_INTERFACE=0.0.0.0
GENIEACS_CWMP_PORT=7547
GENIEACS_NBI_PORT=7557
GENIEACS_FS_PORT=7567
GENIEACS_UI_PORT=3000
GENIEACS_LOG_FORMAT=json
GENIEACS_ACCESS_LOG_FORMAT=json
GENIEACS_UI_WORKER_PROCESSES=1
GENIEACS_CWMP_WORKER_PROCESSES=1
GENIEACS_NBI_WORKER_PROCESSES=1
GENIEACS_FS_WORKER_PROCESSES=1
